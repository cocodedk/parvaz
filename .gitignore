# ── Go (core/) ──────────────────────────────────────────────────
*.exe
*.test
*.out
coverage.out
/bin/
/dist/
vendor/
/core/parvaz
/core/parvazd

# ── Android / Gradle (app/) ─────────────────────────────────────
.gradle/
build/
/app/build/
/app/release/
captures/
.cxx/
local.properties
*.keystore
*.jks
!release.keystore.gpg

# ── JniLibs bundled Go binaries (built per release) ─────────────
/app/src/main/jniLibs/*/libparvaz.so

# ── Editor / OS ─────────────────────────────────────────────────
.idea/
.vscode/
*.swp
.DS_Store

# ── Local secrets — never commit ────────────────────────────────
config.json
.env
.env.*
!.env.example
/scripts/e2e/live.env
/scripts/e2e/build/
# clasp per-account binding — contains scriptId for the deployer's
# own Google account; must never land in git.
/reference/apps_script/.clasp.json
/reference/apps_script/.clasprc.json

# ── Review artifacts (codex / opencode CLI workspace dumps) ─────
# Per-commit diff + log files written by /codex-review and
# /opencode-review when run locally. ~14k lines of these slipped
# into PR #41 before this rule existed.
/oc-*.diff
/oc-*.log
/opencode-*.diff
/opencode-*.log
.codex

# ── Claude Code runtime (keep settings.json tracked) ────────────
# settings.json is the shared project config (tracked).
# settings.local.json holds per-developer overrides (e.g. extra allowed
# tools); the lock file is the scheduler's session-local state.
/.claude/settings.local.json
/.claude/scheduled_tasks.lock
/.claude/scheduled_tasks.json
