<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Foreground-service gating.
         FOREGROUND_SERVICE_SPECIAL_USE pairs with the
         foregroundServiceType="specialUse" on ParvazVpnService (see
         the service block for why "vpn" isn't usable on compileSdk 36).
         POST_NOTIFICATIONS is runtime-granted on API 33+; without it
         the ongoing notification is silently dropped. -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <!-- ACCESS_NETWORK_STATE lets us fail fast with "no internet" copy
         before spawning the TUN/sidecar. Normal permission, no runtime
         prompt. -->
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <!-- INTERNET is required for the Go sidecar (spawned as a child
         process via ProcessBuilder) to bind its local SOCKS5 port and
         dial out to script.google.com. Without it, AF_INET socket
         creation returns EPERM because Android gates that on the inet
         group, which is granted only when this permission is declared. -->
    <uses-permission android:name="android.permission.INTERNET" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Parvaz">
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.Parvaz.Starting">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

            <!--
              parvaz:// deep links — pasted from Telegram, tapped from a
              helper's message, or delivered by the QR scanner. Custom
              scheme (not an HTTPS app link), so autoVerify is irrelevant.
            -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="parvaz" />
            </intent-filter>
        </activity>

        <!--
          FileProvider exposes the API 24-28 fallback path used by
          CaExporter (filesDir external Download/ ) so the "Show file"
          CTA can hand a content URI to ACTION_VIEW without requesting
          WRITE_EXTERNAL_STORAGE. Authority namespaced under the
          applicationId; mapped paths live in res/xml/file_paths.xml.
        -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

        <!--
          ParvazVpnService establishes the TUN interface and launches the
          Go sidecar. Android triggers the system consent dialog on first
          bind; from then on BIND_VPN_SERVICE guards the service itself.
        -->
        <service
            android:name=".vpn.ParvazVpnService"
            android:exported="false"
            android:foregroundServiceType="specialUse"
            android:permission="android.permission.BIND_VPN_SERVICE">
            <!--
              `compileSdk` 36's AAPT does not recognise "vpn" as a flag
              value for foregroundServiceType (the bitmask omits it).
              `specialUse` is the catch-all for services outside the
              named categories; Android 14+ requires the matching
              PROPERTY_SPECIAL_USE_FGS_SUBTYPE to declare our intent.
            -->
            <property
                android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
                android:value="vpn_tunnel" />
            <intent-filter>
                <action android:name="android.net.VpnService" />
            </intent-filter>
        </service>
    </application>

</manifest>
