<?xml version="1.0" encoding="utf-8"?>
<paths>
    <!--
      Exposes app-scoped external Downloads (filesDir/Download/) so that
      the API 24-28 fallback path in CaExporter can hand a content URI
      to the system's "Open file" intent without requesting the legacy
      WRITE_EXTERNAL_STORAGE runtime permission.
    -->
    <external-files-path
        name="ca_export"
        path="Download/" />

    <!--
      Cache subdir for APKs downloaded by the in-app updater. Hands a
      content URI to the system PackageInstaller via ACTION_VIEW
      (application/vnd.android.package-archive) without WRITE_EXTERNAL_STORAGE.
    -->
    <cache-path
        name="apk_update"
        path="parvaz-update/" />
</paths>
