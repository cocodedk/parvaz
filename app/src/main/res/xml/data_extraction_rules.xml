<?xml version="1.0" encoding="utf-8"?>
<!--
  Backup / device-transfer rules for Android 12+ (API 31+).
  See https://developer.android.com/about/versions/12/backup-restore#xml-changes

  Same hardening as backup_rules.xml: MITM private key and the relay
  AUTH_KEY must never leave the device. Both cloud-backup AND
  device-transfer paths are blocked — a transfer to a new device that
  resurrects ca.key would defeat the model.
-->
<!-- Mirror any change here in backup_rules.xml — the two files cover
     API-31+ vs pre-API-31 pathways and must stay in sync. -->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="file" path="parvaz-data"/>
        <exclude domain="sharedpref" path="parvaz_secure.xml"/>
    </cloud-backup>
    <device-transfer>
        <exclude domain="file" path="parvaz-data"/>
        <exclude domain="sharedpref" path="parvaz_secure.xml"/>
    </device-transfer>
</data-extraction-rules>
