# Normalize all text files to LF on commit
* text=auto eol=lf

# Kotlin / Gradle / Android
*.kt         text eol=lf
*.kts        text eol=lf
*.xml        text eol=lf
*.pro        text eol=lf
*.properties text eol=lf

# Go
*.go         text eol=lf
*.mod        text eol=lf
*.sum        text eol=lf

# Scripts + shell
*.sh         text eol=lf
gradlew      text eol=lf

# Source / config
*.py         text eol=lf
*.js         text eol=lf
*.ts         text eol=lf
*.json       text eol=lf
*.yaml       text eol=lf
*.yml        text eol=lf
*.md         text eol=lf
*.html       text eol=lf
*.css        text eol=lf
*.toml       text eol=lf
*.gs         text eol=lf
*.gitignore  text eol=lf

# Windows-CRLF exception
gradlew.bat  text eol=crlf

# Binary
*.png        binary
*.jpg        binary
*.jpeg       binary
*.gif        binary
*.webp       binary
*.ico        binary
*.pdf        binary
*.zip        binary
*.jar        binary
*.apk        binary
*.keystore   binary
*.jks        binary
*.tar.gz     binary
