 //
 //	socks5.Server → dispatcher.Dispatcher
 //	                  ├─ direct TCP       (AllowList: accounts/mail/gmail/etc.)
 //	                  ├─ SNI-rewrite      (SNIRewriteList: YouTube / ytimg / ggpht)
 //	                  └─ MITM + relay     (everything else → Apps Script)
 //
