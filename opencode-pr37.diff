+func TestDNSHandler_AAAAQuery_SuppressedLocally(t *testing.T) {
+	var dohHit bool
+	srv := httptest.NewServer(http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {
+		dohHit = true
