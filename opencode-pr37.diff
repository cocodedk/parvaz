+	// wiring the shim in that mode silently drops normal-DNS UDP
+	// targets like 8.8.8.8:53 instead of replying REP=0x07 as
+	// SOCKS5 semantics prescribe (codex-review P3).
+	if cfg.TunFD > 0 {
